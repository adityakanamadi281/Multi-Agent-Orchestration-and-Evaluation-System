# Ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
MODEL_NAME=gemma4:31b-cloud 

# Exa
EXA_API_KEY=your-exa-key-here
EXA_MOCK=false
EXA_MAX_RESULTS=5
EXA_MAX_CHARACTERS=2000
EXA_TIMEOUT_SEC=8
EXA_MAX_CONCURRENT=5

# Web search fallback
WEB_SEARCH_PRIMARY=exa
WEB_SEARCH_MAX_RETRIES=2

# Database
DATABASE_URL=postgresql+asyncpg://multiagent:multiagent@db:5432/multiagent
SYNC_DATABASE_URL=postgresql://multiagent:multiagent@db:5432/multiagent
POSTGRES_USER=multiagent
POSTGRES_PASSWORD=multiagent
POSTGRES_DB=multiagent

# Redis
REDIS_URL=redis://redis:6379

# ChromaDB
CHROMA_PERSIST_DIR=/data/chroma

# Code sandbox
CODE_SANDBOX_TIMEOUT_SEC=10

# Logging
LOG_LEVEL=INFO